# pyramid.obj — pirâmide de base quadrada unitária
# Vértices: 4 cantos da base (z=0) + 1 ápice (centro, z=1)
# Paramétrico: base = AABB(0,0,0 → 1,1,0), apex = centroid_base + (0,0,h)
o pyramid

v 0.0 0.0 0.0
v 1.0 0.0 0.0
v 1.0 1.0 0.0
v 0.0 1.0 0.0
v 0.5 0.5 1.0

# faces laterais
f 1 2 5
f 2 3 5
f 3 4 5
f 4 1 5
# base (dois triângulos)
f 1 3 2
f 1 4 3
