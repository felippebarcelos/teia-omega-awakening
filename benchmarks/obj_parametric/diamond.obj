# diamond.obj — octaedro regular (diamante) centrado na origem, raio=1
# Paramétrico: octahedron(center=(0,0,0), radius=1)
# Cada vértice = ponto cardinal nos 3 eixos: ±X, ±Y, ±Z
o diamond_octahedron

v  0.0  0.0  1.0
v  1.0  0.0  0.0
v  0.0  1.0  0.0
v -1.0  0.0  0.0
v  0.0 -1.0  0.0
v  0.0  0.0 -1.0

# hemisfério superior (vértice 1 = topo)
f 1 2 3
f 1 3 4
f 1 4 5
f 1 5 2
# hemisfério inferior (vértice 6 = base)
f 6 3 2
f 6 4 3
f 6 5 4
f 6 2 5
